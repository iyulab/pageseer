# Rust
/target
**/*.rs.bk
# Cargo.lock is committed: this repo distributes a CLI binary via GitHub
# release, so reproducible builds (`--locked`) require the lock file in VCS.

# IDE
/.idea
/.vscode
*.swp
*~

# OS
.DS_Store
Thumbs.db

# pageseer build/test artifacts
/out
/tmp
*.png.tmp
*.jpg.tmp

# pdfium prebuilt (로컬 전용; CI/릴리스에서는 별도 다운로드)
/pdfium/

# Test fixtures generated at runtime (printpdf-built) or user-placed (hwp/docx)
/tests/fixtures/sample.pdf
/tests/fixtures/sample.hwp
/tests/fixtures/sample.hwpx
/tests/fixtures/sample.docx

# Claude Code local artifacts (user-only, not shared via git)
/CLAUDE.md
/claudedocs/
